Algoritmo "FormulaDeBhaskara"
// 
//  
// Descriçăo   : Aqui vocę descreve o que o programa faz! (funçăo)
// Autor(a)    : Nome do(a) aluno(a)
// Data atual  : 19/03/2026
Var
// Seçăo de Declaraçőes das variáveis 
a, b, c, delta, x1, x2: real

Inicio
// Entrada de dados
   escreva("Digite o valor de a: ")
   leia(a)
   escreva("Digite o valor de b: ")
   leia(b)
   escreva("Digite o valor de c: ")
   leia(c)
   
   // Verificaçăo se é uma equaçăo do segundo grau
   se (a = 0) entao
      escreval("O valor de 'a' deve ser diferente de zero.")
   senao
   
   // Cálculo do Delta
      delta <- (b ^ 2) - (4 * a * c)
      escreval("Delta calculado: ", delta)
      
       // Verificaçăo das raízes
      se (delta < 0) entao
         escreval("A equaçăo năo possui raízes reais.")
      senao
      
       // Cálculo das raízes usando a funçăo raizq (raiz quadrada)
         x1 <- (-b + raizq(delta)) / (2 * a)
         x2 <- (-b - raizq(delta)) / (2 * a)
         
          escreval("x1 = ", x1)
         escreval("x2 = ", x2)
      fimse
   fimse


Fimalgoritmo